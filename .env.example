# Configure one or both providers. Never commit real API keys.
UAV_LLM_PROVIDER=deepseek
# Optional. Useful when HTTP_PROXY/HTTPS_PROXY/ALL_PROXY are all configured.
UAV_LLM_PROXY=
DEEPSEEK_API_KEY=
DEEPSEEK_FLASH_MODEL=deepseek-chat
DEEPSEEK_LITE_MODEL=deepseek-chat
DEEPSEEK_PRO_MODEL=deepseek-chat
GEMINI_API_KEY=
GEMINI_FLASH_MODEL=gemini-3.5-flash
GEMINI_LITE_MODEL=gemini-3.1-flash-lite
GEMINI_PRO_MODEL=gemini-2.5-pro
UAV_AGENT_HOST=127.0.0.1
UAV_AGENT_PORT=8765
