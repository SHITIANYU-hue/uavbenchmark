{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uav-benchmark.local/schemas/task_template_output.schema.json",
  "title": "Reviewable Task Template Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "task_id",
    "batch_ref",
    "case_index",
    "seed",
    "title",
    "narratives",
    "manifest",
    "provenance"
  ],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "artifact_type": {"const": "task_template"},
    "task_id": {"type": "string", "minLength": 1},
    "batch_ref": {"type": "string", "minLength": 1},
    "case_index": {"type": "integer", "minimum": 1},
    "seed": {"type": "integer", "minimum": 0},
    "title": {"type": "string", "minLength": 1},
    "narratives": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review_annotated", "sut_visible", "hidden_gt_note"],
      "properties": {
        "review_annotated": {"type": "string", "minLength": 1},
        "sut_visible": {"type": "string", "minLength": 1},
        "hidden_gt_note": {"type": "string", "minLength": 1}
      }
    },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "objective",
        "coverage",
        "capability_boundaries",
        "completion_conditions",
        "exception_flow",
        "external_dependencies",
        "jd_bindings",
        "tbd_items"
      ],
      "properties": {
        "objective": {"$ref": "#/$defs/sourced_text"},
        "coverage": {"type": "array", "items": {"type": "object"}},
        "capability_boundaries": {"type": "array", "items": {"type": "object"}},
        "completion_conditions": {"type": "array", "items": {"type": "object"}},
        "exception_flow": {
          "type": "object",
          "required": ["text", "status"],
          "properties": {
            "text": {"type": ["string", "null"]},
            "status": {"$ref": "#/$defs/status"}
          }
        },
        "external_dependencies": {"type": "array", "items": {"type": "object"}},
        "jd_bindings": {
          "type": "array",
          "items": {"$ref": "#/$defs/jd_binding"}
        },
        "tbd_items": {
          "type": "array",
          "items": {"$ref": "#/$defs/tbd_item"}
        }
      }
    },
    "provenance": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/provenance"}
    }
  },
  "$defs": {
    "status": {"enum": ["verified", "proposed", "TBD"]},
    "provenance": {
      "type": "object",
      "required": ["source_id", "status"],
      "properties": {
        "source_id": {"type": "string", "minLength": 1},
        "locator": {"type": ["string", "null"]},
        "status": {"$ref": "#/$defs/status"},
        "notes": {"type": ["string", "null"]}
      }
    },
    "sourced_text": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "status", "source"],
      "properties": {
        "text": {"type": "string", "minLength": 1},
        "status": {"$ref": "#/$defs/status"},
        "source": {"type": "string", "minLength": 1}
      }
    },
    "jd_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_id",
        "canonical_jd",
        "name",
        "value",
        "status",
        "configuration_assignment",
        "assignment_status",
        "selected_node_ids",
        "variable_roles",
        "configuration_sides",
        "projection_targets",
        "visibility",
        "observation_channels",
        "metadata_gaps",
        "provenance",
        "edit_history"
      ],
      "properties": {
        "binding_id": {"type": "string", "minLength": 1},
        "canonical_jd": {
          "type": "string",
          "pattern": "^jd-(?:0|[1-9]|1[0-7])\\.[1-9][0-9]*$"
        },
        "name": {"type": "string", "minLength": 1},
        "value": {},
        "status": {"$ref": "#/$defs/status"},
        "configuration_assignment": {
          "enum": ["world", "user", "shared", "hidden_gt", "TBD"]
        },
        "assignment_status": {"$ref": "#/$defs/status"},
        "selected_node_ids": {"type": "array", "items": {"type": "string"}},
        "variable_roles": {"type": "array", "items": {"type": "string"}},
        "configuration_sides": {"type": "array", "items": {"type": "string"}},
        "projection_targets": {"type": "array", "items": {"type": "string"}},
        "visibility": {"type": "array", "items": {"type": "string"}},
        "observation_channels": {"type": "array", "items": {"type": "string"}},
        "metadata_gaps": {"type": "array", "items": {"type": "string"}},
        "provenance": {
          "type": "array",
          "items": {"$ref": "#/$defs/provenance"}
        },
        "edit_history": {"type": "array", "items": {"type": "object"}}
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "TBD"}}},
          "then": {"properties": {"value": {"type": "null"}}}
        }
      ]
    },
    "tbd_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tbd_id",
        "canonical_jd",
        "name",
        "missing",
        "status",
        "resolution_owners",
        "required_before",
        "can_remain_tbd_in_draft"
      ],
      "properties": {
        "tbd_id": {"type": "string", "minLength": 1},
        "canonical_jd": {"type": ["string", "null"]},
        "name": {"type": "string", "minLength": 1},
        "missing": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "status": {"const": "TBD"},
        "resolution_owners": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "business_task_owner",
              "jd_tree_maintainer",
              "task_interface_or_safety_owner",
              "simulator_adapter_owner"
            ]
          }
        },
        "required_before": {
          "enum": [
            "config_agent_handoff",
            "simulator_integration",
            "benchmark_run"
          ]
        },
        "can_remain_tbd_in_draft": {"const": true}
      }
    }
  }
}
