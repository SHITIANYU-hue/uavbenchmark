{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uav-benchmark.local/schemas/user_config.schema.json",
  "title": "SUT-visible User Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "config_id",
    "task_ref",
    "task_text",
    "task_requirements",
    "sut_visible_inputs",
    "allowed_actions",
    "output_contract",
    "external_executor_dependencies",
    "runtime_constraints",
    "hidden_ground_truth",
    "tbd_items",
    "provenance"
  ],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "artifact_type": {"const": "user_config"},
    "config_id": {"type": "string", "minLength": 1},
    "task_ref": {"type": "string", "minLength": 1},
    "task_text": {"type": "string", "minLength": 1},
    "task_requirements": {"type": "array", "items": {"type": "object"}},
    "sut_visible_inputs": {
      "type": "array",
      "items": {"$ref": "task_template_output.schema.json#/$defs/jd_binding"}
    },
    "allowed_actions": {"type": "array", "items": {}},
    "output_contract": {
      "type": "array",
      "items": {"$ref": "task_template_output.schema.json#/$defs/jd_binding"}
    },
    "external_executor_dependencies": {"type": "array", "items": {"type": "object"}},
    "runtime_constraints": {
      "type": "array",
      "items": {
        "allOf": [
          {"$ref": "task_template_output.schema.json#/$defs/jd_binding"},
          {
            "properties": {
              "configuration_assignment": {"enum": ["user", "shared"]}
            }
          }
        ]
      }
    },
    "hidden_ground_truth": {"type": "array", "maxItems": 0},
    "tbd_items": {"type": "array", "items": {"type": "object"}},
    "provenance": {"type": "array", "minItems": 1, "items": {"type": "object"}}
  }
}
