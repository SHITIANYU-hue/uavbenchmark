{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uav-benchmark.local/schemas/ground_truth.schema.json",
  "title": "UAV Benchmark Hidden Ground Truth",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "ground_truth_id",
    "episode_id",
    "instance_ref",
    "visibility",
    "timebase",
    "phase_intervals",
    "objects",
    "platform_truth",
    "localization_faults",
    "safety_truth",
    "expected_external_decisions",
    "generation",
    "provenance"
  ],
  "properties": {
    "schema_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "artifact_type": {"const": "ground_truth"},
    "ground_truth_id": {"$ref": "#/$defs/id"},
    "episode_id": {"$ref": "#/$defs/id"},
    "instance_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["instance_id", "sha256"],
      "properties": {
        "instance_id": {"$ref": "#/$defs/id"},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "visibility": {"const": "grader_only"},
    "timebase": {"$ref": "#/$defs/timebase"},
    "phase_intervals": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/phase_interval"}
    },
    "objects": {"type": "array", "items": {"$ref": "#/$defs/object_truth"}},
    "platform_truth": {"type": "array", "items": {"$ref": "#/$defs/platform_sample"}},
    "localization_faults": {"type": "array", "items": {"$ref": "#/$defs/localization_fault"}},
    "safety_truth": {"type": "array", "items": {"$ref": "#/$defs/safety_sample"}},
    "expected_external_decisions": {
      "type": "array",
      "items": {"$ref": "#/$defs/external_decision"}
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generator", "version", "seed"],
      "properties": {
        "generator": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "seed": {"type": "integer", "minimum": 0},
        "extensions": {"type": "object"}
      }
    },
    "provenance": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/provenance"}
    },
    "extensions": {"type": "object"}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "evidence_status": {"enum": ["verified", "proposed", "TBD"]},
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "status"],
      "properties": {
        "source_id": {"type": "string", "minLength": 1},
        "locator": {"type": ["string", "null"]},
        "status": {"$ref": "#/$defs/evidence_status"},
        "notes": {"type": ["string", "null"]}
      }
    },
    "timebase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "tick_duration_s"],
      "properties": {
        "kind": {"enum": ["tick", "simulation_time", "wall_clock"]},
        "tick_duration_s": {"type": ["number", "null"], "exclusiveMinimum": 0}
      }
    },
    "phase_interval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase_id", "order", "start_tick", "end_tick"],
      "properties": {
        "phase_id": {"$ref": "#/$defs/id"},
        "order": {"type": "integer", "minimum": 0},
        "start_tick": {"type": "integer", "minimum": 0},
        "end_tick": {"type": "integer", "minimum": 0},
        "extensions": {"type": "object"}
      }
    },
    "track_sample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tick", "visible", "state"],
      "properties": {
        "tick": {"type": "integer", "minimum": 0},
        "visible": {"type": "boolean"},
        "state": {"type": "object"},
        "occlusion": {"type": ["string", "null"]},
        "extensions": {"type": "object"}
      }
    },
    "object_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["object_id", "kind", "attributes", "track"],
      "properties": {
        "object_id": {"$ref": "#/$defs/id"},
        "kind": {"type": "string", "minLength": 1},
        "attributes": {"type": "object"},
        "track": {"type": "array", "items": {"$ref": "#/$defs/track_sample"}},
        "extensions": {"type": "object"}
      }
    },
    "platform_sample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tick", "pose", "source_quality"],
      "properties": {
        "tick": {"type": "integer", "minimum": 0},
        "pose": {"type": "object"},
        "source_quality": {"type": "object"},
        "extensions": {"type": "object"}
      }
    },
    "localization_fault": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fault_id", "fault_type", "start_tick", "end_tick", "affected_sources", "parameters"],
      "properties": {
        "fault_id": {"$ref": "#/$defs/id"},
        "fault_type": {"type": "string", "minLength": 1},
        "start_tick": {"type": "integer", "minimum": 0},
        "end_tick": {"type": "integer", "minimum": 0},
        "affected_sources": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "parameters": {"type": "object"},
        "extensions": {"type": "object"}
      }
    },
    "safety_sample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tick", "safe_to_advance", "allowed_executor_actions"],
      "properties": {
        "tick": {"type": "integer", "minimum": 0},
        "safe_to_advance": {"type": "boolean"},
        "allowed_executor_actions": {"type": "array", "items": {"$ref": "#/$defs/id"}},
        "extensions": {"type": "object"}
      }
    },
    "external_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_id", "available_after_tick", "decision", "status"],
      "properties": {
        "decision_id": {"$ref": "#/$defs/id"},
        "available_after_tick": {"type": "integer", "minimum": 0},
        "decision": {"type": ["string", "null"]},
        "status": {"$ref": "#/$defs/evidence_status"},
        "extensions": {"type": "object"}
      },
      "allOf": [
        {"if": {"properties": {"status": {"const": "TBD"}}}, "then": {"properties": {"decision": {"const": null}}}}
      ]
    }
  }
}
