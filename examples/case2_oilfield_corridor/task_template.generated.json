        "a7_l2"
      ],
      "shared_outcome_handling": "no_double_count",
      "status": "proposed"
    },
    {
      "rule_id": "safe_terminal_single_gate",
      "description": "安全返航、备降或安全完成是任务级共享终态，只统计一次。",
