  "title": "油田管廊缺陷巡检",
  "scenario": {
    "summary": "沿固定管廊航段识别缺陷并持续维护相对几何；资源偏差后自主选择资源兜底策略并验证安全终态。",
    "fixed_boundaries": [
      "油田地面管廊或油气集输管线走廊",
      "指定固定巡检、返航和安全备降路线",
      "资源偏差发生前必须存在正常巡检阶段",
      "A11 负责资源决策，A7 负责路线执行，A8 低层控制由外部飞控提供"
    ],
    "out_of_scope": [
      "A6a 定位异常识别与恢复",
      "A8 低层飞行控制评分",
      "A9 载荷动作评分",
      "自然语言交互、人工批准和人工接管评分",
      "动态障碍自主重规划"
    ]
  },
